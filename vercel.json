{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/supabase/(.*)",
      "destination": "/api/supabase-proxy?__path=$1"
    },
    {
      "source": "/api/b2/(.*)",
      "destination": "/api/b2-proxy?__path=$1"
    },
    {
      "source": "/digital/((?!api/|assets/|favicon\\.svg|icons\\.svg|logo\\.png).*)",
      "destination": "/digital/index.html"
    }
  ]
}
